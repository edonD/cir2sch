v {xschem version=3.4.5 file_version=1.2}
K {type=subcircuit
format="@name @pinlist sub_in_lib"
template="name=X1"}
G {}
V {}
S {}
E {}
L 4 -20 -20 20 -20 {}
L 4 20 -20 20 20 {}
L 4 20 20 -20 20 {}
L 4 -20 20 -20 -20 {}
